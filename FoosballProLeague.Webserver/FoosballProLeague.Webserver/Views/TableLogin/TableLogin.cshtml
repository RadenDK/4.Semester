@model FoosballProLeague.Webserver.Models.TableStatusViewModel

@{
    Layout = null;
    var teamColor = Model.Side.ToLower() == "red" ? "red" : "blue";
}

@using System.Text.Json;
@{
    var initialDataJson = JsonSerializer.Serialize(Model.PendingUsers);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FoosballProLeague - Team Login</title>
    <link rel="stylesheet" href="css/tableLogin.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/5.0.11/signalr.min.js"></script>
    <script src="~/js/tableLogin.js"></script>
</head>
<body>
    <div class="login-form">
        <h2 class="team-title @teamColor">
            Logging into @Model.Side Team
        </h2>

        <div class="login-box">
            <form id="loginForm">
                <input type="hidden" id="tableId" name="TableId" value="@ViewBag.TableId" />
                <input type="hidden" id="side" name="Side" value="@Model.Side" />
                <input type="email" name="Email" placeholder="Enter your email" required />
                <button type="submit" class="login @teamColor-btn">Join Team</button>
            </form>

        </div>


        <div class="players-container stacked-layout">
            <div class="team-box red-team-box">
                <h3 class="red-team-title">RED TEAM</h3>
                <div id="red-team-users"></div>
            </div>

            <div class="vs-separator">VS</div>

            <div class="team-box blue-team-box">
                <h3 class="blue-team-title">BLUE TEAM</h3>
                <div id="blue-team-users"></div>
            </div>
        </div>
    </div>

    <!-- Inject the initial pending users data -->
    <script>
        var initialPendingUsers = @Html.Raw(initialDataJson);
    </script>
</body>
</html>
